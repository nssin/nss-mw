rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Public Data: Readable by all nodes, writable strictly by authenticated operators
    match /artifacts/{appId}/public/data/{collectionName}/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Private User Data: Strictly isolated to the specific authenticated operator's UID
    match /artifacts/{appId}/users/{userId}/{collectionName}/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
  }
}